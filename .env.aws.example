# ============================================================================
# GOSH Project - AWS DynamoDB + Lambda Environment Variables
# ============================================================================
# Copy this file to .env and fill in your AWS configuration
# DynamoDB provides lower costs for serverless applications
# ============================================================================

# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
NODE_ENV=production
STAGE=dev
DEPLOY_BACKEND=true
DEPLOY_FRONTEND=true

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
# AWS Region (e.g., us-east-1, us-west-2, eu-west-1, ap-southeast-1)
AWS_REGION=us-east-1

# AWS Account ID (find this in AWS Console)
AWS_ACCOUNT_ID=874373490883

# AWS Access Key ID (for AWS CLI and SDK)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS Secret Access Key (for AWS CLI and SDK)
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ============================================================================
# DYNAMODB CONFIGURATION
# ============================================================================
# DynamoDB Table Name
# Naming convention: gosh-data-{environment}
DYNAMODB_TABLE_NAME=gosh-data-prod

# DynamoDB Billing Mode
# Options: PAY_PER_REQUEST (recommended for low traffic)
#          PROVISIONED (for predictable traffic)
DYNAMODB_BILLING_MODE=PAY_PER_REQUEST

# For PROVISIONED mode only:
# DYNAMODB_READ_CAPACITY=5
# DYNAMODB_WRITE_CAPACITY=5

# Enable DynamoDB Point-in-Time Recovery (for backups)
# Options: true, false
DYNAMODB_POINT_IN_TIME_RECOVERY=true

# ============================================================================
# S3 BUCKET CONFIGURATION
# ============================================================================
# Frontend Assets Bucket (React SPA)
# Naming: gosh-frontend-{environment}-{account-id}
FRONTEND_BUCKET_NAME=gosh-static-webstite-bucket

# Uploads Bucket (User-uploaded files)
# Naming: gosh-uploads-{environment}-{account-id}
UPLOADS_BUCKET_NAME=gosh-file-bucket 

# ============================================================================
# CLOUDFRONT DISTRIBUTION (Optional CDN)
# ============================================================================
# CloudFront Distribution ID (for cache invalidation)
CLOUDFRONT_DISTRIBUTION_ID=E1234ABCDEF5

# CloudFront Domain Name (e.g., d12345.cloudfront.net)
CLOUDFRONT_DOMAIN=d12345.cloudfront.net

# ============================================================================
# API GATEWAY & LAMBDA CONFIGURATION
# ============================================================================
# API Gateway Endpoint (will be generated after Lambda deployment)
API_ENDPOINT=https://yoe7524zbi.execute-api.us-east-1.amazonaws.com

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://gosh-static-webstite-bucket.s3-website-us-east-1.amazonaws.com

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-very-secure-jwt-secret-key-change-me

# Admin Email
ADMIN_EMAIL=admin@gosh.local

# Admin Password
ADMIN_PASSWORD=Admin@123456

# ============================================================================
# LOGGING & MONITORING (Optional)
# ============================================================================
# CloudWatch Logs Group
LOG_GROUP=/aws/lambda/gosh-api-dynamodb

# Enable detailed logging
DEBUG=false

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# These are compiled into the frontend build (must be prefixed with REACT_APP_)

# API Endpoint for frontend requests
REACT_APP_API_ENDPOINT=http://gosh-static-webstite-bucket.s3-website-us-east-1.amazonaws.com

# Frontend bucket name
REACT_APP_FRONTEND_BUCKET_NAME=gosh-static-webstite-bucket

# Uploads bucket name
REACT_APP_UPLOADS_BUCKET_NAME=gosh-file-bucket

# CloudFront domain (if available)
REACT_APP_CLOUDFRONT_DOMAIN=d12345.cloudfront.net

# AWS Region
REACT_APP_AWS_REGION=us-east-1

# ============================================================================
# COST OPTIMIZATION SETTINGS
# ============================================================================

# Enable DynamoDB Streams (for real-time data sync if needed)
# Options: true, false
DYNAMODB_STREAMS_ENABLED=false

# DynamoDB auto-scaling (for PROVISIONED mode)
# Options: true, false
DYNAMODB_AUTO_SCALING=true

# S3 Intelligent-Tiering (automatically move old data to cheaper storage)
# Options: true, false
S3_INTELLIGENT_TIERING=true

# CloudFront caching duration (seconds)
# Higher values = lower costs, lower freshness
CLOUDFRONT_CACHE_TTL=3600

# ============================================================================
# BACKUP & DISASTER RECOVERY
# ============================================================================

# Enable DynamoDB backups
DYNAMODB_BACKUPS_ENABLED=true

# Backup retention days (DynamoDB PITR)
DYNAMODB_BACKUP_RETENTION_DAYS=35

# S3 bucket versioning (for accidental deletions)
S3_VERSIONING_ENABLED=true

# ============================================================================
# NOTES FOR DYNAMODB DEPLOYMENT
# ============================================================================
# 1. Single DynamoDB Table Design:
#    - All data in one table: gosh-data-{environment}
#    - Uses entity type attribute for differentiation
#    - Global Secondary Indexes (GSI) for queries
#    - Pay-per-request billing = lower costs
#
# 2. Table Structure:
#    - Partition Key (PK): entityId (e.g., "SOLUTION#123")
#    - Sort Key (SK): timestamp (for ordering)
#    - GSI 1: type-timestamp-index (query by entity type)
#    - GSI 2: email-index (query customers by email)
#    - GSI 3: id-index (query by entity id)
#
# 3. Cost Benefits:
#    - No monthly server costs (Lambda + DynamoDB)
#    - Pay only for actual usage
#    - Free tier: 25GB storage + 25 write/read units
#    - ~$0 for low traffic apps
#
# 4. Deployment Steps:
#    - Update lambda.ts to use app-dynamodb.ts
#    - Update serverless.yml to serverless-dynamodb.yml
#    - Run: serverless deploy -c serverless-dynamodb.yml
#
# 5. Local Development:
#    - Run: npm run dev:dynamodb (starts local DynamoDB)
#    - Run: npm run dev:lambda (starts Lambda locally)
#    - Data is in-memory, cleared when stopped
#
# 6. Migration from RDS:
#    - Export data from RDS to DynamoDB format
#    - Transform SQL data to DynamoDB items
#    - Run: npm run migrate:rds-to-dynamodb
#
# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
# - Never commit this file to version control
# - Use AWS Secrets Manager for sensitive values in production
# - Rotate JWT_SECRET and passwords regularly
# - Use strong passwords (min 20 characters)
# - Enable MFA for AWS account
# - Use IAM roles instead of access keys when possible
# - Enable CloudTrail for audit logging
# - Enable DynamoDB Point-in-Time Recovery
# - Use VPC endpoints for DynamoDB (no internet exposure)
# ============================================================================

# ============================================================================
# ESTIMATED MONTHLY COSTS (AWS DynamoDB)
# ============================================================================
# Pay-Per-Request (recommended for variable traffic):
# - 100K requests/month: ~$1
# - 1M requests/month: ~$10
# - 10M requests/month: ~$100
# Storage: ~$1.25 per GB/month
#
# Example: Low-traffic app with 1GB storage, 500K requests/month
# DynamoDB: ~$5 + $1.25 = ~$6.25
# S3: ~$0.50
# Lambda: ~$0 (free tier: 1M requests)
# CloudFront: ~$0 (first 1TB free)
# Total: ~$7/month (vs $15-35 with RDS)
#
# Provisioned (for predictable traffic):
# - Base: 5 read units = $2.47/month
# - Base: 5 write units = $0.49/month
# - Good for apps with consistent traffic patterns
# ============================================================================

# Enable SSL for RDS connection (recommended for production)
DB_SSL=true

# ============================================================================
# S3 BUCKET CONFIGURATION
# ============================================================================
# Frontend Assets Bucket (React SPA)
# Naming: gosh-frontend-{environment}-{account-id}
FRONTEND_BUCKET_NAME=gosh-frontend-dev-123456789012

# Uploads Bucket (User-uploaded files)
# Naming: gosh-uploads-{environment}-{account-id}
UPLOADS_BUCKET_NAME=gosh-uploads-dev-123456789012

# ============================================================================
# CLOUDFRONT DISTRIBUTION (Optional CDN)
# ============================================================================
# CloudFront Distribution ID (for cache invalidation)
# Find this in AWS CloudFront console
CLOUDFRONT_DISTRIBUTION_ID=E1234ABCDEF5

# CloudFront Domain Name (e.g., d12345.cloudfront.net)
# If set, all S3 URLs will use this domain instead of S3 direct URLs
CLOUDFRONT_DOMAIN=d12345.cloudfront.net

# ============================================================================
# API GATEWAY & LAMBDA CONFIGURATION
# ============================================================================
# API Gateway Endpoint (will be generated after Lambda deployment)
# Format: https://{api-id}.execute-api.{region}.amazonaws.com/dev
API_ENDPOINT=https://abc123def456.execute-api.us-east-1.amazonaws.com/dev

# Frontend URL (for CORS configuration)
# This should match your frontend domain
FRONTEND_URL=https://gosh-frontend-dev-123456789012.s3.us-east-1.amazonaws.com
# Or if using CloudFront:
# FRONTEND_URL=https://d12345.cloudfront.net

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Secret (generate a strong random string)
# Command: openssl rand -base64 32
JWT_SECRET=your-very-secure-jwt-secret-key-change-me

# Admin Email for Login
ADMIN_EMAIL=admin@gosh.local

# Admin Password for Login
ADMIN_PASSWORD=Admin@123456

# ============================================================================
# LOGGING & MONITORING (Optional)
# ============================================================================
# CloudWatch Logs Group (auto-created by Lambda)
LOG_GROUP=/aws/lambda/gosh-api

# Enable detailed logging
DEBUG=false

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================
# SES Sender Email (must be verified in AWS SES)
SES_SENDER_EMAIL=noreply@gosh.local

# SES Region (can be different from main region)
SES_REGION=us-east-1

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# These are compiled into the frontend build (must be prefixed with REACT_APP_)

# API Endpoint for frontend requests
REACT_APP_API_ENDPOINT=https://abc123def456.execute-api.us-east-1.amazonaws.com/dev

# Frontend bucket name
REACT_APP_FRONTEND_BUCKET_NAME=gosh-frontend-dev-123456789012

# Uploads bucket name
REACT_APP_UPLOADS_BUCKET_NAME=gosh-uploads-dev-123456789012

# CloudFront domain (if available)
REACT_APP_CLOUDFRONT_DOMAIN=d12345.cloudfront.net

# AWS Region
REACT_APP_AWS_REGION=us-east-1

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 1. Create RDS Database:
#    - PostgreSQL 14+ or MySQL 8.0+
#    - Public access: No (use VPC/Security groups)
#    - Create admin user and initial database
#
# 2. Create S3 Buckets:
#    - Frontend bucket: Enable static website hosting
#    - Uploads bucket: Block all public access (use presigned URLs)
#    - Run: bash setup-aws.sh
#
# 3. Create IAM User/Role:
#    - S3 permissions for both buckets
#    - Lambda permissions
#    - RDS access
#
# 4. Deploy:
#    - Run: bash deploy.sh
#    - Or manually: serverless deploy
#
# 5. Update DNS:
#    - Point domain to API Gateway or CloudFront
#    - Update FRONTEND_URL and API_ENDPOINT accordingly
#
# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
# - Never commit this file to version control
# - Use AWS Secrets Manager for sensitive values in production
# - Rotate JWT_SECRET and passwords regularly
# - Use strong passwords (min 20 characters)
# - Enable MFA for AWS account
# - Use IAM roles instead of access keys when possible
# - Enable CloudTrail for audit logging
# - Enable S3 versioning and lifecycle policies
# ============================================================================
