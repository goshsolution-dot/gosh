# Production environment variables
# Update these with your actual AWS resources

# API Gateway endpoint for Lambda backend
REACT_APP_API_ENDPOINT=https://yoe7524zbi.execute-api.us-east-1.amazonaws.com

# S3 buckets
REACT_APP_FRONTEND_BUCKET_NAME=gosh-static-webstite-bucket
REACT_APP_UPLOADS_BUCKET_NAME=gosh-file-bucket

# CloudFront distribution (if using)
REACT_APP_CLOUDFRONT_DOMAIN=https://YOUR_CLOUDFRONT_DOMAIN_HERE

# AWS Region
REACT_APP_AWS_REGION=us-east-1
