{
  "name": "gosh-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "handler": "dist/lambda.handler",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:lambda": "serverless offline start",
    "build": "tsc",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node18 --outfile=dist/lambda.js",
    "start": "node dist/server.js",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "logs": "serverless logs -f api",
    "invoke:local": "serverless invoke local -f api"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "aws-serverless-express": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "pg": "^8.11.3",
    "sequelize": "^6.33.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/aws-serverless-express": "^3.3.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.19",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.13.2",
    "esbuild": "^0.19.10",
    "serverless": "^3.36.0",
    "serverless-esbuild": "^1.48.4",
    "serverless-offline": "^13.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
